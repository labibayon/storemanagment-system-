import javax.swing.*;
import java.awt.*;
import java.awt.event.*;
import java.util.List;

class StoreManagementUI {
    private JFrame frame;
    private ProductDAO productDAO;
    private CustomerDAO customerDAO;
    private OrderDAO orderDAO;

    public StoreManagementUI() {
        productDAO = new ProductDAO();
        customerDAO = new CustomerDAO();
        orderDAO = new OrderDAO();

        showLoginScreen();
    }

    private void showLoginScreen() {
        JFrame loginFrame = new JFrame("🔐 Admin Login");
        loginFrame.setSize(350, 220);
        loginFrame.setLayout(new GridLayout(4, 1, 10, 10));
        loginFrame.setLocationRelativeTo(null);

        JPanel userPanel = new JPanel(new FlowLayout());
        JLabel userLabel = new JLabel("Username:");
        JTextField userField = new JTextField(15);
        userPanel.add(userLabel);
        userPanel.add(userField);

        JPanel passPanel = new JPanel(new FlowLayout());
        JLabel passLabel = new JLabel("Password:");
        JPasswordField passField = new JPasswordField(15);
        passPanel.add(passLabel);
        passPanel.add(passField);

        JButton loginButton = new JButton("Login");
        loginButton.setBackground(new Color(60, 179, 113));
        loginButton.setForeground(Color.WHITE);
        loginButton.setFont(new Font("Segoe UI", Font.BOLD, 14));

        JLabel messageLabel = new JLabel("", SwingConstants.CENTER);
        messageLabel.setForeground(Color.RED);

        loginButton.addActionListener(e -> {
            String username = userField.getText();
            String password = new String(passField.getPassword());
            if (username.equals("admin") && password.equals("admin123")) {
                loginFrame.dispose();
                showDashboard();
            } else {
                messageLabel.setText("❌ Invalid login. Try again.");
            }
        });

        loginFrame.add(userPanel);
        loginFrame.add(passPanel);
        loginFrame.add(loginButton);
        loginFrame.add(messageLabel);

        loginFrame.setVisible(true);
    }

    private void showDashboard() {
        frame = new JFrame("  allah'r dan Store  ");
        frame.setSize(750, 550);
        frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        frame.setLayout(new BorderLayout());
        frame.setLocationRelativeTo(null);
        frame.getContentPane().setBackground(new Color(224, 255, 255)); // Light cyan

        JPanel menuPanel = new JPanel(new GridLayout(7, 1, 10, 10));
        menuPanel.setBackground(new Color(240, 248, 255));
        menuPanel.setBorder(BorderFactory.createEmptyBorder(20, 40, 20, 40));

        JLabel header = new JLabel(" Store Manager Dashboard", SwingConstants.CENTER);
        header.setFont(new Font("Segoe UI", Font.BOLD, 24));
        header.setForeground(new Color(25, 25, 112));

        JButton btnAddProduct = styleButton(" Add Product");
        JButton btnViewProducts = styleButton(" View Products");
        JButton btnDeleteProduct = styleButton(" Delete Product");
        JButton btnAddCustomer = styleButton(" Add Customer");
        JButton btnViewCustomers = styleButton(" View Customers");
        JButton btnPlaceOrder = styleButton(" Place Order");
        JButton btnExit = styleButton(" Exit");

        menuPanel.add(btnAddProduct);
        menuPanel.add(btnViewProducts);
        menuPanel.add(btnDeleteProduct);
        menuPanel.add(btnAddCustomer);
        menuPanel.add(btnViewCustomers);
        menuPanel.add(btnPlaceOrder);
        menuPanel.add(btnExit);

        frame.add(header, BorderLayout.NORTH);
        frame.add(menuPanel, BorderLayout.CENTER);

        btnAddProduct.addActionListener(e -> addProduct());
        btnViewProducts.addActionListener(e -> viewProducts());
        btnDeleteProduct.addActionListener(e -> deleteProduct());
        btnAddCustomer.addActionListener(e -> addCustomer());
        btnViewCustomers.addActionListener(e -> viewCustomers());
        btnPlaceOrder.addActionListener(e -> placeOrder());
        btnExit.addActionListener(e -> System.exit(0));

        frame.setVisible(true);
    }

    private JButton styleButton(String text) {
        JButton button = new JButton(text);
        button.setFocusPainted(false);
        button.setFont(new Font("Tahoma", Font.BOLD, 16));
        button.setBackground(new Color(70, 130, 180)); // Steel Blue
        button.setForeground(Color.WHITE);
        button.setBorder(BorderFactory.createLineBorder(new Color(25, 25, 112), 2));
        return button;
    }

    private void addProduct() {
        JTextField nameField = new JTextField();
        JTextField priceField = new JTextField();
        JTextField quantityField = new JTextField();
        Object[] inputFields = {
                "🌐 Name:", nameField,
                "💲 Price:", priceField,
                "📦 Quantity:", quantityField
        };
        int result = JOptionPane.showConfirmDialog(frame, inputFields, "Add Product", JOptionPane.OK_CANCEL_OPTION);
        if (result == JOptionPane.OK_OPTION) {
            try {
                String name = nameField.getText();
                double price = Double.parseDouble(priceField.getText());
                int quantity = Integer.parseInt(quantityField.getText());
                if (price < 0 || quantity < 0) throw new NumberFormatException();
                productDAO.addProduct(new Product(0, name, price, quantity));
            } catch (NumberFormatException ex) {
                JOptionPane.showMessageDialog(frame, "❌ Invalid input. Try again.");
            }
        }
    }

    private void viewProducts() {
        List<Product> products = productDAO.getAllProducts();
        String[] columns = {"ID", "Name", "Price", "Quantity"};
        Object[][] data = new Object[products.size()][4];
        for (int i = 0; i < products.size(); i++) {
            Product p = products.get(i);
            data[i][0] = p.getProductId();
            data[i][1] = p.getName();
            data[i][2] = p.getPrice();
            data[i][3] = p.getQuantity();
        }
        JTable table = new JTable(data, columns);
        styleTable(table);
        JScrollPane scrollPane = new JScrollPane(table);
        JOptionPane.showMessageDialog(frame, scrollPane, "Product List", JOptionPane.INFORMATION_MESSAGE);
    }

    private void deleteProduct() {
        String idStr = JOptionPane.showInputDialog(frame, "Enter Product ID to delete:");
        if (idStr != null && !idStr.isEmpty()) {
            try {
                int id = Integer.parseInt(idStr);
                productDAO.deleteProduct(id);
            } catch (NumberFormatException e) {
                JOptionPane.showMessageDialog(frame, "❌ Invalid Product ID.");
            }
        }
    }

    private void addCustomer() {
        JTextField nameField = new JTextField();
        JTextField emailField = new JTextField();
        Object[] inputFields = {
                "👤 Name:", nameField,
                "📧 Email:", emailField
        };
        int result = JOptionPane.showConfirmDialog(frame, inputFields, "Add Customer", JOptionPane.OK_CANCEL_OPTION);
        if (result == JOptionPane.OK_OPTION) {
            customerDAO.addCustomer(new Customer(0, nameField.getText(), emailField.getText()));
        }
    }

    private void viewCustomers() {
        List<Customer> customers = customerDAO.getAllCustomers();
        String[] columns = {"ID", "Name", "Email"};
        Object[][] data = new Object[customers.size()][3];
        for (int i = 0; i < customers.size(); i++) {
            Customer c = customers.get(i);
            data[i][0] = c.getCustomerId();
            data[i][1] = c.getName();
            data[i][2] = c.getEmail();
        }
        JTable table = new JTable(data, columns);
        styleTable(table);
        JScrollPane scrollPane = new JScrollPane(table);
        JOptionPane.showMessageDialog(frame, scrollPane, "Customer List", JOptionPane.INFORMATION_MESSAGE);
    }

    private void placeOrder() {
        JTextField customerIdField = new JTextField();
        JTextField productIdField = new JTextField();
        JTextField quantityField = new JTextField();
        Object[] inputFields = {
                "🧾 Customer ID:", customerIdField,
                "📦 Product ID:", productIdField,
                "🔢 Quantity:", quantityField
        };
        int result = JOptionPane.showConfirmDialog(frame, inputFields, "Place Order", JOptionPane.OK_CANCEL_OPTION);
        if (result == JOptionPane.OK_OPTION) {
            try {
                int cid = Integer.parseInt(customerIdField.getText());
                int pid = Integer.parseInt(productIdField.getText());
                int qty = Integer.parseInt(quantityField.getText());
                if (qty <= 0) throw new NumberFormatException();
                OrderResult order = orderDAO.placeOrder(cid, pid, qty);
                if (order != null) {
                    JOptionPane.showMessageDialog(frame,
                            "✅ Order ID: " + order.getOrderId() + "\n💰 Total Price: " + order.getTotalPrice(),
                            "Order Placed", JOptionPane.INFORMATION_MESSAGE);
                } else {
                    JOptionPane.showMessageDialog(frame, "❌ Failed to place order.");
                }
            } catch (NumberFormatException e) {
                JOptionPane.showMessageDialog(frame, "❌ Invalid input. Try again.");
            }
        }
    }

    private void styleTable(JTable table) {
        table.setRowHeight(25);
        table.setFont(new Font("Segoe UI", Font.PLAIN, 14));
        table.getTableHeader().setFont(new Font("Segoe UI", Font.BOLD, 14));
    }

    public static void main(String[] args) {
        SwingUtilities.invokeLater(StoreManagementUI::new);
    }
}
